:- module(constraints, [
    check_constraints/1
]).

:- use_module(library(chr)).

/** <module> CHR Policy Constraints
 * 
 * Enforces structural invariants on Prolog skills using Constraint Handling Rules.
 * Every proposed clause is run through these rules before assertion.
 */

:- chr_constraint check_constraints/1, banned_predicate/1, complexity_limit/1.

% Rule: Ban direct KB mutation predicates
check_constraints(Clause) <=> find_banned(Clause).

% Recursive search for banned predicates in the body of a clause
find_banned((_ :- Body)) :- !, find_banned(Body).
find_banned((A, B)) :- !, find_banned(A), find_banned(B).
find_banned((A ; B)) :- !, find_banned(A), find_banned(B).
find_banned(not(A)) :- !, find_banned(A).
find_banned(\+ A) :- !, find_banned(A).
find_banned(Goal) :-
    functor(Goal, Name, _),
    is_banned(Name)
    -> banned_predicate(Name)
    ;  true.

% Policy: These predicates are strictly forbidden in skills
is_banned(assert).
is_banned(asserta).
is_banned(assertz).
is_banned(retract).
is_banned(retractall).
is_banned(abolish).
is_banned(shell).
is_banned(process_create).

% Handle the constraints
banned_predicate(Name) <=> 
    format(atom(Msg), 'Use of banned predicate: ~w. Direct KB mutation or shell access is forbidden.', [Name]),
    throw(safety_violation(Msg)).
